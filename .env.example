CODECANIC_REDIRECT_URI=https://codecanic.app/api/oauth/callback
CODECANIC_SESSION_SECRET=replace-with-a-long-random-string

# Data layer. In production set DATABASE_URL to a managed Postgres connection
# string (Railway Postgres / Neon / Supabase). When DATABASE_URL is unset, the
# app falls back to an embedded Postgres (PGlite) persisted under CODECANIC_DATA_DIR
# — fine for local dev, NOT for production (single-process, local disk).
DATABASE_URL=
CODECANIC_DATA_DIR=.data

# Transactional email (verification + password reset). With RESEND_API_KEY set,
# email is delivered via Resend and email verification is enforced before
# scanning. Without it, signups are auto-verified (we don't lock users out of a
# feature they can't unlock). Set CODECANIC_REQUIRE_EMAIL_VERIFICATION=1 to
# enforce verification regardless. CODECANIC_APP_URL sets the link base.
RESEND_API_KEY=
CODECANIC_EMAIL_FROM=Codecanic <noreply@codecanic.app>
CODECANIC_APP_URL=https://codecanic.app
CODECANIC_REQUIRE_EMAIL_VERIFICATION=

# Observability. Structured JSON request logging is always on. Set SENTRY_DSN to
# report exceptions to Sentry (no-op when unset).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub App (least-privilege, per-repo access — preferred over the broad OAuth
# `repo` scope). Register an App, set its Setup URL to
# ${CODECANIC_APP_URL}/api/oauth/github-app-callback, and provide:
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
RAILWAY_TOKEN=
APPLE_TEAM_ID=

# Billing: Pro upgrade (ad-free + unlimited scans). Without these, the app
# stays free + ad-supported and checkout reports "not configured".
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Advanced / tuning (all optional; sensible defaults shown) ---
# PORT=3000
# CODECANIC_ALLOWED_ORIGINS=          # extra comma-separated origins allowed for CSRF/state-changing requests
# CODECANIC_SCAN_ALLOWED_HOSTS=github.com,gitlab.com,bitbucket.org  # repo hosts the scanner may clone
# CODECANIC_ALLOW_EPHEMERAL_DB=       # set to 1 to permit booting on ephemeral PGlite in production (DATA LOSS — throwaway envs only)
# CODECANIC_DISABLE_WORKER=           # set to 1 to run the API without the in-process job worker (use a separate worker)
# CODECANIC_WORKER_POLL_MS=1000       # idle poll interval for the job worker
# CODECANIC_WORKER_STALE_MS=600000    # re-queue jobs left 'running' longer than this (crash recovery)
# CODECANIC_MAX_JOB_ATTEMPTS=3        # delivery attempts before a job is marked permanently failed
# CODECANIC_PG_POOL=10                # max Postgres pool connections
# CODECANIC_PG_CONNECT_TIMEOUT_MS=8000
# CODECANIC_PG_IDLE_TIMEOUT_MS=30000
# CODECANIC_PG_STATEMENT_TIMEOUT_MS=30000
# CODECANIC_PG_INSECURE_SSL=          # set to 1 to disable Postgres TLS cert verification (only if your provider requires it)
# CODECANIC_PGLITE_MEMORY=            # set to 1 to use an in-memory PGlite (tests)
# CODECANIC_SCAN_TMP=                 # override the temp dir used for repo clones during scans
